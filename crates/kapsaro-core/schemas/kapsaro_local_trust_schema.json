{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kapsaro.local.trust.schema.json",
  "title": "kapsaro local trust schema",
  "description": "Local Trust Store: TOFU approval cache for known key IDs and artifact recipient sets",
  "$defs": {
    "recipient_handle_hint": {
      "type": "object",
      "properties": {
        "kid": { "$ref": "kapsaro_common_schema.json#/$defs/kid" },
        "recipient_handle": { "$ref": "kapsaro_common_schema.json#/$defs/member_handle" }
      },
      "required": ["kid", "recipient_handle"],
      "additionalProperties": false
    },
    "recipient_set": {
      "type": "object",
      "properties": {
        "sid": { "$ref": "kapsaro_common_schema.json#/$defs/uuid" },
        "recipient_kids": {
          "type": "array",
          "items": { "$ref": "kapsaro_common_schema.json#/$defs/kid" }
        },
        "recipient_set_hash": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "approved_at": { "$ref": "kapsaro_common_schema.json#/$defs/rfc3339_utc" },
        "approved_via": { "$ref": "kapsaro_common_schema.json#/$defs/approved_via" },
        "recipient_handle_hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/recipient_handle_hint" }
        }
      },
      "required": ["sid", "recipient_kids", "recipient_set_hash", "approved_at", "approved_via"],
      "additionalProperties": false
    },
    "known_key": {
      "type": "object",
      "properties": {
        "kid": { "$ref": "kapsaro_common_schema.json#/$defs/kid" },
        "subject_handle": { "$ref": "kapsaro_common_schema.json#/$defs/member_handle" },
        "approved_at": { "$ref": "kapsaro_common_schema.json#/$defs/rfc3339_utc" },
        "approved_via": { "$ref": "kapsaro_common_schema.json#/$defs/approved_via" },
        "evidence": { "$ref": "kapsaro_common_schema.json#/$defs/known_key_evidence" }
      },
      "required": ["kid", "subject_handle", "approved_at", "approved_via"],
      "additionalProperties": true
    }
  },
  "type": "object",
  "properties": {
    "protected": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "const": "kapsaro:format:local-trust@1"
        },
        "owner_handle": { "$ref": "kapsaro_common_schema.json#/$defs/member_handle" },
        "created_at": { "$ref": "kapsaro_common_schema.json#/$defs/rfc3339_utc" },
        "updated_at": { "$ref": "kapsaro_common_schema.json#/$defs/rfc3339_utc" },
        "known_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/known_key" }
        },
        "recipient_sets": {
          "type": "array",
          "items": { "$ref": "#/$defs/recipient_set" }
        }
      },
      "required": ["format", "owner_handle", "created_at", "updated_at", "known_keys", "recipient_sets"],
      "additionalProperties": false
    },
    "signature": {
      "type": "object",
      "properties": {
        "alg": { "type": "string" },
        "kid": { "$ref": "kapsaro_common_schema.json#/$defs/kid" },
        "sig": { "type": "string" }
      },
      "additionalProperties": false,
      "required": ["alg", "kid", "sig"]
    }
  },
  "required": ["protected", "signature"],
  "additionalProperties": false
}
