{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "secretenv.artifact.signature.schema.json",
  "title": "secretenv artifact signature schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "alg": { "$ref": "secretenv_common_schema.json#/$defs/sig_alg" },
    "kid": { "$ref": "secretenv_common_schema.json#/$defs/kid" },
    "signer_pub": { "$ref": "secretenv_public_key_schema.json" },
    "sig": {
      "$ref": "secretenv_common_schema.json#/$defs/b64url_64",
      "description": "Ed25519 raw signature 64 bytes encoded as base64url (no padding, 86 characters)"
    }
  },
  "required": ["alg", "kid", "signer_pub", "sig"]
}
